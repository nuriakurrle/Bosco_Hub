# =============================================================
# Plantilla de configuración para el servidor (VPS).
#
# En el servidor: copia este archivo a .env  y rellena los valores.
#   cp .env.prod.example .env
#
# NUNCA subas el .env real a git (ya está ignorado).
# Para generar contraseñas/claves seguras en el servidor:
#   openssl rand -base64 24
# =============================================================

# --- Base de datos Postgres ---
POSTGRES_USER=zuk
POSTGRES_PASSWORD=CAMBIA_ESTA_CONTRASEÑA
POSTGRES_DB=zuk

# --- Login de la interfaz de n8n (http://IP:5678) ---
N8N_BASIC_AUTH_USER=zuk
N8N_BASIC_AUTH_PASSWORD=CAMBIA_ESTA_CONTRASEÑA

# --- Clave para cifrar las credenciales que guarda n8n (Outlook, etc.) ---
# Genérala una vez con: openssl rand -base64 24  y NO la cambies después.
N8N_ENCRYPTION_KEY=CAMBIA_ESTA_CLAVE

# --- IP pública o dominio del servidor (sin http://) ---
# Ej: 5.75.123.45   o   boscohub.midominio.com
SERVER_HOST=PON_AQUI_LA_IP_DEL_SERVIDOR

# --- OpenAI (transcripción de llamadas: Whisper + extracción + Realtime) ---
# En el CI se inyecta desde el secreto de GitHub OPENAI_API_KEY.
OPENAI_API_KEY=CAMBIA_ESTA_CLAVE
