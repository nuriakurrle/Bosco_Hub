    {
      "parameters": {
        "jsCode": "// Pre-classify which house / responsible area the email belongs to,\n// based on the address it was sent to. This mirrors how the ZUK team\n// already uses the old mailbox addresses as a routing signal.\n\nconst to = ($json.to || '').toLowerCase();\n\nlet houseHint = 'unknown';\nlet responsibleArea = 'unassigned';\n\nif (to.includes('jugendherberge') || (to.includes('info') && to.includes('dboe'))) {\n  houseHint = 'Jugendherberge';\n  responsibleArea = 'Jugendherberge bookings';\n} else if (to.includes('streidel') || to.includes('aktionszentrum')) {\n  houseHint = 'Aktionszentrum';\n  responsibleArea = 'Aktionszentrum bookings';\n}\n\nreturn [{\n  json: {\n    ...$json,\n    house_hint: houseHint,\n    responsible_area: responsibleArea\n  }\n}];"
      },
      "id": "node-routing",
      "name": "Detect Routing",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [680, 420]
    },
    {
      "parameters": {
