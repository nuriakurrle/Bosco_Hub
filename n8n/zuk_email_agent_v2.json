        "query": "SELECT id, school_name, date_range, received_at FROM inquiries WHERE school_name ILIKE '%' || $1 || '%' ORDER BY received_at DESC LIMIT 5",
        "options": {
          "queryReplacement": "={{ $fromAI('school_name', 'Name der Schule oder Gruppe') }}"
