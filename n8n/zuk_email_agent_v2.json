      "id": "node-tool-dup",
      "name": "Duplicate Check",
      "type": "n8n-nodes-base.postgresTool",
      "typeVersion": 2.5,
      "position": [1300, 640],
      "credentials": {
        "postgres": { "id": "bjtHqY4LrBLXQHrN", "name": "Postgres account" }
