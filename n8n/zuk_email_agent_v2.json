      "id": "node-model",
      "name": "OpenAI Chat Model",
      "type": "@n8n/n8n-nodes-langchain.lmChatOpenAi",
      "typeVersion": 1.2,
      "position": [820, 640],
      "credentials": {
        "openAiApi": { "id": "KNbs9IV7QsyP8Jem", "name": "OpenAI account" }
      }
    },
    {
      "parameters": {
        "schemaType": "manual",
        "inputSchema": "{\n  \"type\": \"object\",\n  \"properties\": {\n    \"request_count\": { \"type\": \"number\" },\n    \"summary\": { \"type\": \"string\" },\n    \"requests\": {\n      \"type\": \"array\",\n      \"items\": {\n        \"type\": \"object\",\n        \"properties\": {\n          \"school_name\": { \"type\": \"string\" },\n          \"contact_person\": { \"type\": \"string\" },\n          \"program_type\": { \"type\": \"string\" },\n          \"house\": { \"type\": \"string\" },\n          \"date_range\": { \"type\": \"string\" },\n          \"number_of_people\": { \"type\": \"string\" },\n          \"grade_level\": { \"type\": \"string\" },\n          \"special_requirements\": { \"type\": \"string\" },\n          \"missing_fields\": { \"type\": \"array\", \"items\": { \"type\": \"string\" } },\n          \"status\": { \"type\": \"string\" },\n          \"contains_sensitive_data\": { \"type\": \"boolean\" },\n          \"sensitive_data_note\": { \"type\": \"string\" },\n          \"email_type\": { \"type\": \"string\", \"enum\": [\"booking\", \"other\"] },\n          \"is_returning_customer\": { \"type\": \"boolean\" },\n          \"possible_duplicate_id\": { \"type\": [\"number\", \"null\"] }\n        },\n        \"required\": [\"status\", \"missing_fields\", \"contains_sensitive_data\", \"email_type\"]\n      }\n    }\n  },\n  \"required\": [\"requests\", \"request_count\"]\n}"
      },
