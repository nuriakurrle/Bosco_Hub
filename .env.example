# Conexión a la base de datos Postgres que comparte n8n.
# Estos valores coinciden con el docker-compose de Downloads/zuk_proto.
# Copia este archivo a .env.local y ajusta si cambias las credenciales.
DATABASE_URL=postgresql://zuk:zuk_prototype_2026@localhost:5434/zuk

# Base de n8n (para disparar el envío de la confirmación vía webhook).
N8N_BASE_URL=http://localhost:5678
